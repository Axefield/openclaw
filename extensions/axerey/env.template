# Vagogon Environment Configuration
# Copy this file to .env and update with your actual credentials

# Database Configuration
PCM_DB=./pcm.db

# API Keys (from npm run setup-admin)
# MCP Key for MCP protocol authentication
MCP_API_KEY=axerey_YOUR_MCP_KEY_HERE

# OpenAI Configuration (Optional - for embeddings)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Node Environment
NODE_ENV=production

# Logging Configuration
LOG_LEVEL=INFO
DEBUG=mcp:*

# Optional: Custom Configuration Path
CONFIG_PATH=.Vagogon.scientific

# Optional: Vector Similarity Search Configuration
VSS_ENABLED=false
VECTOR_DIMENSION=1536
