# Ouranigon Web Application Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# HTTPS Configuration
# Set USE_HTTPS=true to enable HTTPS (requires SSL certificates)
USE_HTTPS=false
# Path to SSL certificate (PEM format)
SSL_CERT_PATH=./certs/cert.pem
# Path to SSL private key (PEM format)
SSL_KEY_PATH=./certs/key.pem

# Database Configuration
PCM_DB=./ouranigon.db
VSS_DB=./ouranigon-vss.db

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
# Default model for text generation/chat (supports thinking)
# Small models for limited memory (4-5GB available):
#   - qwen2.5:1.5b (~1GB) - Smallest thinking model, fastest
#   - qwen2.5:3b (~2GB) - Good balance of size and quality
#   - qwen2.5:7b (~4GB) - Better quality, needs more memory
# Larger models (if you have 8GB+):
#   - qwen3 (varies by variant)
#   - deepseek-r1 (7B+)
#   - deepseek-v3.1 (7B+)
# Falls back to qwen2.5:1.5b if not set (smallest thinking model)
OLLAMA_DEFAULT_MODEL=qwen2.5:1.5b
# Embedding model for vector generation (falls back to nomic-embed-text if not set)
# nomic-embed-text is small (~274MB) and efficient
OLLAMA_EMBED_MODEL=nomic-embed-text
# Web Search API Key (optional - enables web search functionality)
# Get your free API key from: https://ollama.com
# Free tier available for individuals with generous rate limits
OLLAMA_WEB_SEARCH_API_KEY=your-ollama-api-key-here

# Security
JWT_SECRET=your-super-secret-jwt-key-here
BCRYPT_ROUNDS=12

# User Sync (for parent domain integration)
# Shared secret key for authenticating sync requests from parent domain
SYNC_SECRET=your-super-secret-sync-key-here

# API Keys (optional - can also be passed in requests)
# Get these from: npm run setup-admin
# API_KEY=axerey_YOUR_API_KEY_HERE

# Logging
LOG_LEVEL=info

# Cloudflare API (for automated certificate generation)
# Get your API token from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: SSL:Edit, Zone:Read
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here
CLOUDFLARE_ZONE_ID=your-zone-id-here  # Optional - will auto-detect from domain
CLOUDFLARE_DOMAIN=truligon.com        # Your domain name (truligon.com for this setup)

# Truligon Architecture
# Main domain: truligon.com (port 443, Cloudflare Tunnel)
# Axerey subdomain: ar.truligon.com (this backend)
# User sync source: ut.truligon.com (syncs users to Axerey)
AXEREY_SUBDOMAIN=ar.truligon.com      # Where Axerey will be accessible
SYNC_SOURCE_DOMAIN=ut.truligon.com    # Source domain for user sync (optional)
